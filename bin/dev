#!/usr/bin/env ruby
# frozen_string_literal: true

ROOT_DIR = File.expand_path("..", __dir__)
$LOAD_PATH.unshift(File.join(ROOT_DIR, "lib"))

require "dev/all"

if $PROGRAM_NAME == __FILE__
  begin
    Dev::Command.call(*ARGV)
  rescue ArgumentError, TypeError => e
    warn e.message
    exit 1
  end
end
