#!/usr/bin/env ruby
# frozen_string_literal: true

require "shellwords"

class DevHelper
  DEFAULT_CONFIG = {
    compose: ["docker", "compose"],
    services: {
      api: "api",
      web: "web",
      db: "db"
    },
    commands: {
      api_shell: ["sh"],
      web_shell: ["sh"],
      api_test: ["npm", "run", "test"],
      web_test: ["npm", "run", "test"],
      api_check_types: ["npm", "run", "check-types"],
      web_check_types: ["npm", "run", "check-types"]
    }
  }.freeze

  COMMAND_TO_METHOD = {
    "up" => :up,
    "down" => :down,
    "logs" => :logs,
    "ps" => :ps,
    "build" => :build,
    "run" => :run_compose,
    "exec" => :exec_compose,
    "sh" => :sh,
    "api" => :api,
    "web" => :web,
    "npm" => :npm,
    "test" => :test,
    "check-types" => :check_types
  }.freeze

  HELP_COMMANDS = [nil, "help", "--help", "-h"].freeze

  def self.call(*args)
    new.call(*args)
  end

  def initialize(config_path: ENV.fetch("MARLENS_DEV_CONFIG", "dev.config.rb"))
    @config = deep_merge(DEFAULT_CONFIG, load_config(config_path))
  end

  def call(command = nil, *args)
    return help if HELP_COMMANDS.include?(command)

    method = COMMAND_TO_METHOD.fetch(command, nil)
    return public_send(method, *args) if method

    compose(command, *args)
  end

  def up(*args)
    compose("up", "--remove-orphans", *args)
  end

  def down(*args)
    compose("down", "--remove-orphans", *args)
  end

  def logs(*args)
    compose("logs", "-f", *args)
  end

  def ps(*args)
    compose("ps", *args)
  end

  def build(*args)
    compose("build", *args)
  end

  def run_compose(*args)
    compose("run", "--rm", *args)
  end

  def exec_compose(*args)
    compose("exec", *args)
  end

  def sh(*args)
    run_service(service(:api), command(:api_shell), args)
  end

  def api(*args)
    run_service(service(:api), args)
  end

  def web(*args)
    run_service(service(:web), args, ["--no-deps"])
  end

  def npm(*args)
    run_service(service(:api), ["npm", *args])
  end

  def test(service_name = nil, *args)
    case service_name
    when "web"
      run_service(service(:web), [*command(:web_test), *args], ["--no-deps"])
    when "api"
      run_service(service(:api), [*command(:api_test), *args])
    else
      run_service(service(:api), [*command(:api_test), service_name, *args].compact)
    end
  end

  def check_types(*args)
    system_or_exit(*config.fetch(:compose), "run", "--rm", service(:api), *command(:api_check_types), *args)
    run_service(service(:web), [*command(:web_check_types), *args], ["--no-deps"])
  end

  def help
    puts <<~HELP
      Usage: marlens-dev <command> [args]

      Generic Docker Compose development wrapper. Copy or configure with dev.config.rb for project-local service names and commands.

      Commands:
        up [services...]          docker compose up --remove-orphans
        down                      docker compose down --remove-orphans
        logs [services...]        docker compose logs -f
        ps                        docker compose ps
        build [services...]       docker compose build
        run <service> <cmd...>    docker compose run --rm <service> <cmd...>
        exec <service> <cmd...>   docker compose exec <service> <cmd...>
        sh                        shell in the API service
        api <cmd...>              run command in the API service
        web <cmd...>              run command in the web service without dependencies
        npm <args...>             run npm in the API service
        test [api|web] [args...]  run configured API or web test command
        check-types [args...]     run configured API then web type checks

      Config:
        Create dev.config.rb in the project root:

        {
          services: { api: "api", web: "web", db: "db" },
          commands: {
            api_test: ["npm", "run", "test"],
            web_test: ["npm", "run", "test"],
            api_check_types: ["npm", "run", "check-types"],
            web_check_types: ["npm", "run", "check-types"]
          }
        }
    HELP
  end

  private

  attr_reader :config

  def load_config(config_path)
    return {} unless File.exist?(config_path)

    result = eval(File.read(config_path), binding, config_path) # rubocop:disable Security/Eval
    result || {}
  end

  def deep_merge(base, override)
    base.merge(override) do |_key, old_value, new_value|
      if old_value.is_a?(Hash) && new_value.is_a?(Hash)
        deep_merge(old_value, new_value)
      else
        new_value
      end
    end
  end

  def compose(*args)
    run(*config.fetch(:compose), *args)
  end

  def run_service(service_name, command_args = [], compose_args = [])
    compose("run", "--rm", *compose_args, service_name, *command_args)
  end

  def service(name)
    config.fetch(:services).fetch(name)
  end

  def command(name)
    config.fetch(:commands).fetch(name)
  end

  def run(*args)
    warn "Running: #{args.shelljoin}"
    exec(*args)
  end

  def system_or_exit(*args)
    warn "Running: #{args.shelljoin}"
    return if system(*args)

    exit($?.exitstatus || 1)
  end
end

DevHelper.call(*ARGV)
